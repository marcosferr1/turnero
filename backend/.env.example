# Base de datos
DATABASE_URL="postgresql://postgres:1234@localhost:5432/turnero-local-db"

# API
PORT=3001
JWT_SECRET="cambiar-por-un-secreto-largo"

# Zona horaria fija (Argentina, sin DST)
APP_UTC_OFFSET="-03:00"

# WhatsApp: "simulator" | "cloud" (Meta directo) | "twilio" | "baileys"
WHATSAPP_MODE="simulator"

# --- Baileys (WHATSAPP_MODE=baileys) — sin Meta; escaneás QR una vez ---
BAILEYS_PHONE="5493517714542"
BAILEYS_AUTH_DIR=".baileys_auth"
# Opcional: protege /baileys/qr en producción (?token=...)
BAILEYS_QR_SECRET=""
# URL pública del backend (Railway la infiere con RAILWAY_PUBLIC_DOMAIN si no la seteás)
PUBLIC_URL=""

# --- Meta Cloud API (WHATSAPP_MODE=cloud) ---
WHATSAPP_TOKEN=""
WHATSAPP_VERIFY_TOKEN="turnero-verify"
WHATSAPP_API_VERSION="v21.0"
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_USE_TEMPLATES="false"

# --- Twilio WhatsApp (WHATSAPP_MODE=twilio) ---
# Console: https://console.twilio.com
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# Sandbox: whatsapp:+14155238886 | Producción: tu número aprobado en Twilio
TWILIO_WHATSAPP_FROM=""
# Opcional: Messaging Service SID (si no usás TWILIO_WHATSAPP_FROM)
TWILIO_MESSAGING_SERVICE_SID=""

# Recordatorios por email cuando la ventana WhatsApp de 24 hs está cerrada.
# Opción A — Resend (requiere dominio verificado para producción)
RESEND_API_KEY=""
# Opción B — Gmail u otro SMTP (contraseña de aplicación de Google, no la clave normal)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
# Remitente visible. Con Gmail podés usar: Turnos <tu@gmail.com>
EMAIL_FROM=""
