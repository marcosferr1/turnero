# =============================================================================
# PRODUCCIÓN (Railway) — obligatorias
# =============================================================================
# DATABASE_URL          Connection string pooled de Neon (...-pooler...)
# JWT_SECRET            openssl rand -hex 32  (nunca "dev-secret" en prod)
# WHATSAPP_MODE         baileys
# BAILEYS_PHONE         ej. 5493517714542
# BAILEYS_QR_SECRET     openssl rand -hex 24  (protege /baileys/qr)
# APP_UTC_OFFSET        -03:00
# CORS_ORIGIN           URL del panel Vercel, ej. https://tu-panel.vercel.app
#                       Varios orígenes separados por coma (previews Vercel)
# NODE_ENV              production
#
# NO setear PORT en Railway (lo inyecta la plataforma).
#
# VERCEL (panel): VITE_API_URL=https://tu-backend.up.railway.app
# =============================================================================

# Base de datos
DATABASE_URL="postgresql://postgres:1234@localhost:5432/turnero-local-db"

# API (local: 3001; Railway setea PORT solo)
PORT=3001
NODE_ENV="development"
JWT_SECRET="cambiar-por-un-secreto-largo"

# Orígenes permitidos del panel (vacío en local = CORS abierto)
CORS_ORIGIN="http://localhost:5174"

# Rate limit login (opcional)
LOGIN_RATE_LIMIT_MAX="10"
LOGIN_RATE_LIMIT_WINDOW_MS="900000"

# Zona horaria fija (Argentina, sin DST)
APP_UTC_OFFSET="-03:00"

# WhatsApp: "simulator" | "cloud" | "twilio" | "baileys"
WHATSAPP_MODE="simulator"

# --- Baileys (WHATSAPP_MODE=baileys) ---
BAILEYS_PHONE="5493517714542"
BAILEYS_AUTH_DIR=".baileys_auth"
# Obligatorio en producción. Protege GET /baileys/qr (?token=...)
BAILEYS_QR_SECRET=""
# URL pública del backend (Railway). En local, si está vacío, se usa http://localhost:PORT
PUBLIC_URL=""

# --- Meta Cloud API (WHATSAPP_MODE=cloud) ---
WHATSAPP_TOKEN=""
WHATSAPP_VERIFY_TOKEN="turnero-verify"
WHATSAPP_API_VERSION="v21.0"
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_USE_TEMPLATES="false"

# --- Twilio WhatsApp (WHATSAPP_MODE=twilio) ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM=""
TWILIO_MESSAGING_SERVICE_SID=""

# Recordatorios por email
RESEND_API_KEY=""
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM=""
